HRMS_APP_NAME=HRMS API
HRMS_APP_VERSION=1.0.0
HRMS_ENVIRONMENT=development
HRMS_DEBUG=true
HRMS_API_V1_PREFIX=/api/v1
HRMS_DATABASE_URL=sqlite:///./hrms.db
HRMS_BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
HRMS_LOG_LEVEL=INFO
HRMS_SECRET_KEY=your-super-secret-key-change-in-production
HRMS_ACCESS_TOKEN_EXPIRE_MINUTES=30
HRMS_REFRESH_TOKEN_EXPIRE_DAYS=7
HRMS_ALGORITHM=HS256
